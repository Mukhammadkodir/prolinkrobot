BOT_TOKEN=your_telegram_bot_token
OFFSET=0
TIMEOUT=60
UPDATE_WORKERS=8
UPDATE_QUEUE_SIZE=128
CACHE_WORKERS=2
CACHE_QUEUE_SIZE=128

MONGODB_URI=mongodb://user:password@host1:27017,host2:27017,host3:27017/?authSource=admin&replicaSet=your-replica-set&retryWrites=true&w=majority&tls=true
MONGODB_DB=freepikusers
MONGODB_TELEGRAM_USERS_COLLECTION=telegram_users
MONGODB_ASSET_CACHE_COLLECTION=asset_cache
ADMIN_TELEGRAM_IDS=318146229,6043524846,125426342
CACHE_CHANNEL_ID=-1001234567890
CACHE_MAX_UPLOAD_BYTES=52428800
TIMEZONE=Asia/Tashkent
TRIAL_PERIOD_DAYS=7
DEFAULT_DAILY_LIMIT=1
FREEPIK_AUTH_CHECK_INTERVAL_MINUTES=5
FREEPIK_AUTH_WARN_MINUTES=20
FREEPIK_AUTH_CRITICAL_MINUTES=5
FREEPIK_AUTH_REFRESH_BEFORE_MINUTES=15

# Optional Firebase Web API key. If set, GR_REFRESH can refresh GR_TOKEN without browser fallback.
# FREEPIK_FIREBASE_API_KEY=

# Optional browser-based refresh fallback. Requires a local Chrome/Chromium binary.
# FREEPIK_BROWSER_REFRESH_ENABLED=false
# FREEPIK_BROWSER_PATH=/usr/bin/google-chrome-stable
# FREEPIK_BROWSER_HEADLESS=true
# FREEPIK_BROWSER_TIMEOUT_SECONDS=90
# FREEPIK_BROWSER_WAIT_SECONDS=8
# FREEPIK_BROWSER_USER_DATA_DIR=/opt/prolinkrobot/shared/chrome-profile

# Option A: use ready-to-send cookie header string
# FREEPIK_COOKIE_HEADER=_ga=...; GR_TOKEN=...; csrf_freepik=...

# Option B: point to a JSON file exported from browser cookies
# When the file contains GR_REFRESH, the bot will auto-refresh GR_TOKEN.
FREEPIK_COOKIES_FILE=freepik_cookies.json

# Optional: overrides csrf_freepik cookie value
# FREEPIK_CSRF_TOKEN=
